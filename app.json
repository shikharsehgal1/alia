{
  "expo": {
    "name": "Alia",
    "slug": "alia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alia",
    "userInterfaceStyle": "automatic",
    "sdkVersion": "53.0.0",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyBafJwGgZ9B10l6cH5x9wfJLv5ye6lTDMw"
      },
      "bundleIdentifier": "com.anonymous.alia"
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBafJwGgZ9B10l6cH5x9wfJLv5ye6lTDMw"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.alia"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://alia.app"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Alia to use your location to find people and places nearby."
        }
      ]
    ]
  }
}
